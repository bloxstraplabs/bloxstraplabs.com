---
const { class: className, ...rest } = Astro.props;
---

<style>
    /* direct porting of tailwind classes */
    
    .footer-ads-container {
        --spacing: 0.25rem; 

        display: grid; 
        gap: calc(var(--spacing) * 8); 
       
        @media (width >= 48rem) {
            grid-template-columns: repeat(2, minmax(0px, 1fr));
        }
        
        .footer-ad {
            max-width: calc(var(--spacing) * 96);
            margin-inline: auto;
            
            * {
                margin-inline: auto;
            }
        }
    }

</style>

<section class={className} {...rest}>
    <div class="footer-ads-container">
        {/*
        <div class="footer-ad">
            <div style="background-color: white; width: 300px; height: 300px;"></div>
        </div>
        
        <div class="footer-ad">
            <div style="background-color: white; width: 300px; height: 300px;"></div>
        </div>
        */}
    
        <div class="footer-ad">
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-7390460488561029"
                 data-ad-slot="4235985449"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> 
        </div>
        
        <div class="footer-ad">
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-7390460488561029"
                 data-ad-slot="4235985449"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> 
        </div>
    </div>
</section>
