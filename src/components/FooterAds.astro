---
import "../styles/ads.css";
const { class: className, ...rest } = Astro.props;
---

<section class={className} {...rest}>
    <div class="footer-ads-container">
        <div class="footer-ad">
            <script
                async
                src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1646308239542585"
                crossorigin="anonymous"></script>
            <ins
                class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-1646308239542585"
                data-ad-slot="2531670857"
                data-ad-format="auto"
                data-full-width-responsive="true"></ins>
            <script>
                window.addEventListener("load", function () {
                    // console.log("Pushed");
                    (adsbygoogle = window.adsbygoogle || []).push({});
                });
            </script>
        </div>

        <div class="footer-ad">
            <script
                async
                src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1646308239542585"
                crossorigin="anonymous"></script>
            <ins
                class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-1646308239542585"
                data-ad-slot="2531670857"
                data-ad-format="auto"
                data-full-width-responsive="true"></ins>
            <script>
                window.addEventListener("load", function () {
                    // console.log("Pushed");
                    (adsbygoogle = window.adsbygoogle || []).push({});
                });
            </script>
        </div>

        <div class="footer-ads-notice">
            <p>Advertisements &mdash; beware of any sketchiness :(</p>
        </div>
    </div>
</section>
